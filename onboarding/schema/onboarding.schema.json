{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Onboarding manifest",
  "type": "object",
  "required": ["customer_name","display_name","environment","contact_email","location","tags"],
  "properties": {
    "customer_name": {"type":"string","pattern":"^[a-z0-9-]{1,32}$"},
    "display_name": {"type":"string","minLength":1},
    "environment": {"type":"string","enum":["shared","dedicated"]},
    "contact_email": {"type":"string","format":"email"},
    "location": {"type":"string"},
    "tags": {"type":"object","additionalProperties":{"type":"string"}},
    "workspace_id": {"type":"string"},
    "customer_entra_group_object_id": {"type":"string"},
    "fslogix_profile_share": {"type":"string"},
    "subscription_id": {"type":"string","pattern":"^/subscriptions/[0-9a-fA-F-]{36}$|^[0-9a-fA-F-]{36}$"},
    "hub_vnet_id": {"type":"string"},
    "avd_image_id": {"type":"string"},
    "user_count": {"type":"integer","minimum":0}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "environment": { "const": "shared" } } },
      "then": { "required": ["workspace_id","fslogix_profile_share"] }
    },
    {
      "if": { "properties": { "environment": { "const": "dedicated" } } },
      "then": { "required": ["subscription_id","hub_vnet_id","user_count"] }
    }
  ]
}
